{#
  指标表模板 - 用于规划指标表格

  参数:
  - title: 表格标题
  - headers: 表头列表
  - rows: 数据行列表
  - caption: 表格说明（可选）
#}
{% if title %}**{{ title }}**{% endif %}

| {% for header in headers %}{{ header }} | {% endfor %}
| {% for header in headers %}:--- | {% endfor %}
{% for row in rows %}| {% for cell in row %}{{ cell }} | {% endfor %}
{% endfor %}

{% if caption %}*{{ caption }}*{% endif %}
