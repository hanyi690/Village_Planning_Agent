# Environment variables for Docker deployment
# Copy this file to .env and fill in your values

# ============================================
# LLM Configuration
# ============================================
# Provider: deepseek, openai, or zhipuai (required)
LLM_PROVIDER=deepseek

# DeepSeek Configuration (Default)
# DeepSeek uses OpenAI-compatible API
OPENAI_API_KEY=your_deepseek_api_key_here
OPENAI_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
MAX_TOKENS=8192

# LLM Concurrency Limit (important for DashScope/qwen models)
# DashScope limit: ~5-10 concurrent requests per account
# Recommended: 3-4 for stability, avoids 429/503 errors
# LLM_MAX_CONCURRENT=4

# Alternative: OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_API_BASE=  # Leave empty for official OpenAI API
# LLM_MODEL=gpt-4o

# Alternative: ZhipuAI (GLM)
# LLM_PROVIDER=zhipuai
# ZHIPUAI_API_KEY=your_zhipuai_api_key_here
# LLM_MODEL=glm-4-flash

# ============================================
# Embedding Model Configuration
# ============================================
# Embedding Provider: local (HuggingFace) 或 aliyun (阿里云 DashScope API)
# 推荐: aliyun (无需本地模型，内存占用低，适合低配服务器)
EMBEDDING_PROVIDER=aliyun

# ============================================
# 本地模型配置 (EMBEDDING_PROVIDER=local)
# ============================================
# Chinese embedding model for RAG knowledge base
# 注意: 本地模型加载需要约 1-2GB 内存
# EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
# EMBEDDING_DEVICE=cpu

# HuggingFace mirror (auto-used when model not cached)
# Default: https://hf-mirror.com (Alibaba Cloud mirror, fast in China)
# HF_ENDPOINT=https://hf-mirror.com

# Force offline/online mode (usually not needed, auto-detected)
# Set HF_HUB_OFFLINE=1 to force offline (fail if model not cached)
# Set HF_HUB_OFFLINE=0 to force online (always check for updates)
# HF_HUB_OFFLINE=
# TRANSFORMERS_OFFLINE=

# ============================================
# 阿里云 DashScope Embedding API (EMBEDDING_PROVIDER=aliyun)
# ============================================
# 文档: https://help.aliyun.com/zh/model-studio/text-embedding-synchronous-api
# 支持的模型: text-embedding-v4 (推荐), text-embedding-v3, text-embedding-v2
# text-embedding-v4 支持可变维度: 2048/1536/1024/768/512/256/128/64
# 内存占用: 极低 (API 调用，无需本地模型)
DASHSCOPE_API_KEY=your_dashscope_api_key
ALIYUN_EMBEDDING_MODEL=text-embedding-v4
# EMBEDDING_DIMENSIONS=1024

# ============================================
# Multimodal (Vision) Configuration
# ============================================
# Enable multimodal support for image analysis in planning workflow
# When enabled, uploaded images will be sent to vision-capable LLM
MULTIMODAL_ENABLED=true

# Multimodal model - use DashScope OpenAI-compatible interface
# DashScope supports: qwen-vl-plus, qwen-vl-max, qwen3.5-plus (with vision)
# Note: Set OPENAI_API_BASE to DashScope endpoint for multimodal
MULTIMODAL_MODEL=qwen3.5-plus

# Image detail level for OpenAI API: low, high, or auto
IMAGE_DETAIL_LEVEL=auto

# Max image size for multimodal processing (bytes)
MAX_IMAGE_SIZE_MULTIMODAL=10000000

# ============================================
# DashScope Multimodal Setup (Recommended)
# ============================================
# To use DashScope for multimodal, configure:
# OPENAI_API_KEY=<your_dashscope_api_key>
# OPENAI_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# MULTIMODAL_MODEL=qwen3.5-plus
#
# Note: This uses OpenAI-compatible interface, no new provider needed

# ============================================
# Backend Configuration
# ============================================
ENVIRONMENT=production
USE_ASYNC_DATABASE=true

# Port configuration (optional, defaults shown)
# BACKEND_PORT=8000
# FRONTEND_PORT=3000

# CORS allowed origins (comma-separated)
# IMPORTANT: Add your public frontend URL for production deployment
# Example: http://localhost:3000,http://your-server-ip:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# Frontend Configuration (IMPORTANT for Production)
# ============================================
# This URL must be accessible from the browser (NOT Docker internal network)
# 
# For local testing:
#   NEXT_PUBLIC_API_URL=http://localhost:8000
#
# For production deployment:
#   NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:8000
#   OR
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com (if using reverse proxy)
#
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Production Deployment Guide
# ============================================
# 
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env with your configuration:
#    - Set ZHIPUAI_API_KEY to your API key
#    - Set NEXT_PUBLIC_API_URL to your server's public address
#    - Set ALLOWED_ORIGINS to include your frontend's public address
#
# 3. Deploy with Docker Compose:
#    docker-compose up -d
#
