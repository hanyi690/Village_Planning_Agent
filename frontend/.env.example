# Village Planning Agent - Frontend Environment Configuration
# Copy this file to .env.local for local development

# ============================================
# API Configuration (REQUIRED)
# ============================================
# Backend API URL - must be accessible from browser
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# GIS Tile Source Configuration
# ============================================
# Available options: tianditu, geoq, openstreetmap
NEXT_PUBLIC_TILE_SOURCE=tianditu

# ============================================
# Production Deployment Notes
# ============================================
# For production deployment:
# 1. Copy this file to .env.local
# 2. Update NEXT_PUBLIC_API_URL to match your server:
#    - Same machine: http://localhost:8000
#    - Different server: http://YOUR_SERVER_IP:8000
# 3. Run npm run dev (or npm run build + npm start)