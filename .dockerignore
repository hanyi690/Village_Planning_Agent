# Docker ignore file for Village Planning Agent
# Excludes unnecessary files from Docker build context

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.venv/
venv/
env/
ENV/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Next.js
frontend/.next/
frontend/out/

# Build artifacts
build/
dist/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment files
.env
.env.local
.env.*.local
*.env

# Logs
logs/
*.log

# Database files (should be mounted as volumes)
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.db-shm
data/*.db-wal

# Results (should be mounted as volumes)
results/

# Git
.git/
.gitignore

# Docker
docker-compose*.yml
.docker/
*.Dockerfile
Dockerfile*

# Documentation
*.md
!README.md
docs/

# Tests
tests/
.pytest_cache/
.coverage
htmlcov/

# Temporary files
nul
=*
*.tmp
*.temp

# Conversation logs
conversation-*.txt

# Style test images
style-test-*.png
*-verification.jpg

# Claude Code
.claude/
.iflow/
